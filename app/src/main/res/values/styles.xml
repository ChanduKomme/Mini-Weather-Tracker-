<resources>
    <!-- Keeps the EditText underline/accent black without changing app theme -->
    <style name="ThemeOverlay.BlackUnderlineEdit" parent="">
        <item name="colorControlNormal">@android:color/black</item>
        <item name="colorControlActivated">@android:color/black</item>
        <item name="colorControlHighlight">@android:color/black</item>
        <!-- Optional: ensure hint text is readable on black background -->
        <item name="android:textColorHint">@android:color/darker_gray</item>
    </style>
</resources>
