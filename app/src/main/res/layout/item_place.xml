<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/row_place_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardUseCompatPadding="true"
    app:cardElevation="0dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@android:color/transparent">

    <!-- Glass container: semi-transparent fill, no border -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/row_place"
        android:layout_width="match_parent"
        android:layout_height="116dp"
        android:padding="14dp"
        android:background="@drawable/bg_card_glass_solid">

        <!-- Default star -->
        <TextView
            android:id="@+id/tvDefaultStar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:textColor="@android:color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- City name -->
        <TextView
            android:id="@+id/tvPlaceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/home_city_sample"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvDefaultStar"/>

        <!-- Temp + (hidden) condition -->
        <LinearLayout
            android:id="@+id/rowTemp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvPlaceTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_temp_placeholder"
                android:textStyle="bold"
                android:textSize="32sp"
                android:textColor="@android:color/black"/>

            <TextView
                android:id="@+id/tvPlaceCond"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_cond_placeholder"
                android:textSize="18sp"
                android:textColor="@android:color/black"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Coords (kept hidden) -->
        <TextView
            android:id="@+id/tvPlaceCoords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_coords_placeholder"
            android:textSize="12sp"
            android:textColor="@android:color/black"
            android:alpha="0.85"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPlaceName"/>

        <!-- ACTIONS: firmly at bottom-right corner of the card -->
        <LinearLayout
            android:id="@+id/actionsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="0dp"
            android:layout_marginBottom="0dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tvMakeDefault"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/home_btn_default"
                android:textColor="@android:color/black"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                app:cornerRadius="8dp"
                app:strokeColor="#1A000000"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tvRemove"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/home_btn_remove"
                android:textColor="@android:color/black"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                app:cornerRadius="8dp"
                app:strokeColor="#1A000000"
                app:strokeWidth="1dp"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
