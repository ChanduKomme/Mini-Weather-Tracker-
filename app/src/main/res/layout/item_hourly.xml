<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardUseCompatPadding="true"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent">

    <!-- Glass card surface (same drawable as Today) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:padding="14dp"
        android:background="@drawable/bg_card_glass_solid">

        <!-- Time -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4 AM"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Emoji icon (simple, no extra deps) -->
        <TextView
            android:id="@+id/tvIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="☁️"
            android:textSize="24sp"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTime"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Temp big -->
        <TextView
            android:id="@+id/tvTemp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="54°"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/tvIcon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="10dp"/>

        <!-- RealFeel -->
        <TextView
            android:id="@+id/tvFeels"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RealFeel® 52°"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/tvTemp"
            app:layout_constraintTop_toTopOf="@id/tvTemp"
            android:layout_marginStart="14dp"/>

        <!-- Precip % on right -->
        <TextView
            android:id="@+id/tvPrecip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6%"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
