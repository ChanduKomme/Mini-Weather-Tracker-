<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">

    <!-- Rounded corners (same as before) -->
    <corners android:radius="16dp"/>

    <!-- Glassy vertical gradient (top brighter -> bottom more transparent) -->
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#66FFFFFF"
        android:centerColor="#33FFFFFF"
        android:endColor="#11FFFFFF"/>

    <!-- Subtle edge to sell the glass effect -->
    <stroke
        android:width="1dp"
        android:color="#44FFFFFF"/>

</shape>
